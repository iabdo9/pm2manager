# ---------------------------------------------------------------------------
# PM2 Manager — environment configuration
#
# Copy this file to `.env` and adjust the values for your deployment:
#     cp .env.example .env
#
# Every value is validated at startup; invalid configuration fails fast.
# Only SESSION_SECRET truly must be changed for production.
# ---------------------------------------------------------------------------

# --- Server ----------------------------------------------------------------
# Interface to bind. Keep 127.0.0.1 when running behind a reverse proxy
# (Nginx/Caddy). Only bind 0.0.0.0 if you deliberately expose the port.
HOST=127.0.0.1
PORT=3000

# "production" or "development" (affects log formatting + safety warnings).
NODE_ENV=production

# Set "true" when running behind a TLS-terminating reverse proxy, so the app
# trusts X-Forwarded-* headers (correct client IPs and Secure cookies).
TRUST_PROXY=false

# --- Security --------------------------------------------------------------
# REQUIRED in production. Long random string used to sign the session cookie.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Rolling idle-session timeout, in minutes (resets on every request).
SESSION_TIMEOUT_MINUTES=30

# "Secure" flag on the session cookie: auto | true | false.
#   auto  -> Secure whenever TRUST_PROXY=true (i.e. served over HTTPS)
#   false -> use only for plain-HTTP / LAN access (cookie works without TLS)
COOKIE_SECURE=auto

# Login / 2FA brute-force protection: failed attempts allowed per window.
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15

# Issuer name shown in authenticator apps during 2FA (TOTP) enrolment.
TOTP_ISSUER=PM2 Manager

# --- Database --------------------------------------------------------------
# Path to the SQLite file (created automatically, with its parent directory).
DATABASE_PATH=./data/pm2manager.sqlite

# --- Metrics history -------------------------------------------------------
# How often (in seconds) PM2 process metrics are sampled into history.
METRICS_INTERVAL_SECONDS=15

# How many days of history to keep. This is also the maximum span the per-process
# Metrics charts can display — raise it (e.g. 30) if you want the "Last 30 days"
# range to actually fill with data.
METRICS_RETENTION_DAYS=7

# --- Logging ---------------------------------------------------------------
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# --- Initial administrator (first run only) --------------------------------
# When the users table is empty on startup, an administrator is created from
# these values. If ADMIN_PASSWORD is left blank, a strong random password is
# generated and printed to the logs ONCE — copy it and change it after login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
